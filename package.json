{
  "name": "react-native-nitro-storage-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "setup": "node scripts/setup.js",
    "publish-package": "node scripts/publish.js",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "clean": "turbo run clean",
    "codegen": "turbo run codegen",
    "typecheck": "turbo run typecheck",
    "test:types": "turbo run test:types --filter=react-native-nitro-storage",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage --filter=react-native-nitro-storage",
    "benchmark": "turbo run benchmark --filter=react-native-nitro-storage",
    "test:cpp": "turbo run test:cpp --filter=react-native-nitro-storage",
    "start": "turbo run start --filter=example --",
    "example:ios": "turbo run ios --filter=example",
    "example:android": "turbo run android --filter=example",
    "example:prebuild": "turbo run prebuild --filter=example",
    "example:prebuild:clean": "turbo run prebuild:clean --filter=example"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.0",
    "eslint-config-expo-magic": "^2.0.2",
    "jest": "^30.2.0",
    "nitrogen": "^0.35.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-builder-bob": "^0.40.18",
    "react-native-nitro-modules": "^0.35.0",
    "react-test-renderer": "^19.2.4",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.6",
    "turbo": "^2.8.10",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-nitro-modules": "^0.35.0",
    "@types/react": "~19.2.0"
  },
  "packageManager": "bun@1.3.9"
}
